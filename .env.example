# ============================================================
#  MATNESS — Environment configuration
#  Copy this file to `.env.local` and fill in real values.
# ============================================================

# --- WhatsApp (THE core conversion CTA) ---------------------
# International format, digits only, no "+", no spaces.
# Example for a Malaysian number +60 12-345 6789  ->  60123456789
NEXT_PUBLIC_WHATSAPP_NUMBER=60123456789

# --- Google Ads conversion tracking -------------------------
# From Google Ads: Tools > Conversions. Format: AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=

# The conversion label for the "WhatsApp click" action.
# Format: AbC-D_efG-hIjKlMnOp  (the part after the "/")
NEXT_PUBLIC_GOOGLE_ADS_WHATSAPP_LABEL=

# --- Google Analytics 4 (optional) --------------------------
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# --- Site URL (used for canonical + OG tags) ----------------
NEXT_PUBLIC_SITE_URL=https://matness.co
